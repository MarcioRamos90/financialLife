# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=financiallife
DB_PASSWORD=changeme_strong_password
DB_NAME=financiallife
DB_HOST=localhost      # overridden to "postgres" inside Docker Compose
DB_PORT=5432

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=8080
# Environment: development | production
APP_ENV=development

# ─── JWT (HS256) ─────────────────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=replace_with_a_random_64_char_string
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=720h   # 30 days

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:5173

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
